# Railway 환경변수 설정 예시
# Railway 대시보드 → Variables 탭에 아래 변수들을 추가하세요

# OpenAI API 키 (스크립트 생성에 필요)
OPENAI_API_KEY=sk-...

# Google OAuth credentials.json 내용 (Base64 인코딩)
# 로컬에서 실행: python3 -c "import base64,open; print(base64.b64encode(open('credentials.json','rb').read()).decode())"
GOOGLE_CREDENTIALS_JSON=eyJ3ZWIiOi...

# YouTube 인증 토큰 (대시보드에서 연결 후 "토큰 내보내기" 버튼으로 획득)
YOUTUBE_TOKEN_PICKLE=gASVAA...

# 포트 (Railway가 자동 설정, 수동 설정 불필요)
# PORT=7860
